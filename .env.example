# 服务端口
PORT=8080

# JWT 签名密钥（生产务必修改）
JWT_SECRET=change-me-in-production

# 首次启动创建的管理员账号密码（仅当数据库为空时生效，之后请在网页内修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# SQLite 数据库路径
DB_PATH=data/domain-lite.db

# Token 有效期（分钟），默认 10080 = 7 天
TOKEN_TTL_MINUTES=10080

# ===== 定时同步 WHOIS =====
# 自动同步周期（分钟），默认 720 = 12 小时
SYNC_INTERVAL_MIN=720

# ===== 临期 Webhook 提醒（默认关闭）=====
NOTIFY_ENABLED=false
# 渠道类型：feishu | wecom | telegram | generic
NOTIFY_TYPE=feishu
# Webhook 地址（飞书/企业微信/Telegram Bot API 的完整 URL）
NOTIFY_WEBHOOK_URL=
# Telegram 需要填写 chat_id（其他渠道留空）
NOTIFY_CHAT_ID=
# 剩余天数 <= 该值则触发提醒，默认 30
NOTIFY_THRESHOLD_DAYS=30
